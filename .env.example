# Supabase Project Configuration (Frontend — Next.js)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Backend Python Worker (bypasses RLS — keep secret, never prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# AMD Developer Cloud FastAPI backend URL
# Set this to the public Cloudflare Tunnel URL pointing to your ROCm container (e.g., https://xxx.trycloudflare.com)
# NOTE: If deploying the frontend to Netlify/Vercel, you must set this variable in their dashboard settings!
NEXT_PUBLIC_AMD_BACKEND_URL=http://YOUR_AMD_CLOUD_INSTANCE_IP:8000

# Fireworks AI — optional Gemma 4 fallback (used only when local vLLM fails)
FIREWORKS_API_KEY=your_fireworks_api_key_here
